server {
    listen 80;
    server_name api.llmstudio.com www.api.llmstudio.com;

    access_log /var/log/nginx/llm_studio.access.log;
    error_log  /var/log/nginx/llm_studio.error.log;

    location / {
        proxy_pass http://127.0.0.1:4557;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_cache_bypass $http_upgrade;
        proxy_buffering off;               # important for streaming / SSE
        client_max_body_size 50M;
    }

    # Optional: redirect /.well-known for certbot
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
}